<mvc:View
    controllerName="mobileappprevpdf.controller.InspRepPDFViewExt"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="page"
        showNavButton="false"
        showHeader="false"
        busy="{view>/busy}"
        busyIndicatorDelay="0">

        <content>

            <!-- ERROR: App opened in browser, not from FSM Mobile -->
            <IllustratedMessage
                visible="{view>/showError}"
                illustrationType="sapIllus-NoMail"
                title="{i18n>errorTitle}"
                description="{i18n>errorDescription}" />

            <!-- Report loading indicator -->
            <BusyIndicator
                visible="{view>/reportLoading}"
                text="{i18n>reportLoading}"
                class="sapUiMediumMarginTop" />

            <!-- Report build error -->
            <MessageStrip
                visible="{view>/reportError}"
                text="{i18n>reportError}"
                type="Error"
                showIcon="true"
                class="sapUiSmallMarginTop" />

            <!-- PDF Preview -->
            <PDFViewer
                id="pdfViewer"
                source="{view>/reportUrl}"
                title="{i18n>reportTitle}"
                visible="{= !!${view>/reportUrl}}"
                isTrustedSource="true"
                height="100%"
                showDownloadButton="true" />

        </content>

    </Page>
</mvc:View>